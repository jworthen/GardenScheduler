rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Share pages: anyone can read; any authenticated user can write
    // (the token itself is the access-control mechanism)
    match /sharePages/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reservations: anyone can create; owner can read and update their own
    match /shareReservations/{id} {
      allow create: if true;
      allow read, update: if request.auth != null
                          && request.auth.uid == resource.data.userId;
    }

    // User profiles: authenticated users can read/write their own doc only
    match /userProfiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Per-user private data (gardens index, legacy data)
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Garden data: owner has full access; members can read and update (not delete)
    // memberUids is stored inside the garden doc itself.
    match /users/{ownerUid}/gardens/{gardenId} {
      allow read: if request.auth != null
                  && (request.auth.uid == ownerUid
                      || (resource != null && request.auth.uid in resource.data.memberUids));
      allow create: if request.auth != null && request.auth.uid == ownerUid;
      allow update: if request.auth != null
                    && (request.auth.uid == ownerUid
                        || request.auth.uid in resource.data.memberUids);
      allow delete: if request.auth != null && request.auth.uid == ownerUid;
    }

    // Invite codes: any authenticated user can read (to join) and create;
    // only the owner can delete their own invite.
    match /gardenInvites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;
    }

    // Feedback submissions
    match /feedbackSubmissions/{id} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null
                          && (request.auth.uid == resource.data.userId
                              || request.auth.token.uid == '${ADMIN_UID}');
    }
  }
}
